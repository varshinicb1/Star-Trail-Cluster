(version 1)
(rule "class 0:0"
  (condition "A.NetClass == 'default' && B.NetClass == 'Default'")
  (constraint clearance (min 0.12mm)))

(rule "class 1:0"
  (condition "A.NetClass == 'PWR' && B.NetClass == 'Default'")
  (constraint clearance (min 0.12mm)))

(rule "class 1:1"
  (condition "A.NetClass == 'PWR' && B.NetClass == 'PWR'")
  (constraint clearance (min 0.1205mm)))
